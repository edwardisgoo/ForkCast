{
  "compilerOptions": {
    "module": "esnext", // 更改為有效的值 (commonjs 是 Node.js 的標準)
    "esModuleInterop": true,
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "noImplicitAny": false
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}